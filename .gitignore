# =========================
# Python cache and bytecode
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Testing caches and reports
# =========================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
reports/
pytest-report.xml
junit*.xml
test_output.txt
test_results_final.txt
test_full_results.txt

# =========================
# Build and packaging
# =========================
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/
spec.d/
onefile_*.txt
dist/installer/*.sha256.txt

# =========================
# Virtual environments and env files
# =========================
.venv/
.venv_*/
venv/
env/
ENV/
.python-version
.env
.env.local
.env.*.local

# =========================
# Editor and OS files
# =========================
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# =========================
# Runtime artifacts and logs (do not commit runtime outputs)
# =========================
/logs/
/models/
/mlruns/
examples/generated/
test-output/
*.json.backup

# =========================
# Temporary and transient files
# =========================
*.tmp
*.temp
*.log
*~

# =========================
# Notebook checkpoints
# =========================
.ipynb_checkpoints/

# =========================
# Large/local data artifacts (keep out of repo)
# =========================
/data/fraud.csv
/data/*.zip

# Optional: commit your lockfile if you prefer reproducible installs
# poetry.lock
