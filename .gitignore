# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Test and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.pyre/
.tox/
.nox/

# Coverage
.coverage
.coverage.*
htmlcov/

# Test reports
.pytest_*.xml
pytest-report.xml
junit*.xml

# Build artifacts
build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# Virtual environments (local dev, packaging, testing)
.venv/
.venv_*/
venv/
env/
ENV/
.python-version
.env

# IDE/editor and OS files
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db

# Runtime app artifacts (repo root)
/logs/
/models/
/examples/generated/
/mlruns/

# Temporary files
*.tmp
*.temp
*.log
*~
.DS_Store
Thumbs.db

# PyInstaller build artifacts (keep build/ in .gitignore)
spec.d/
onefile_*.txt

# Poetry lock files (optional - typically committed)
# poetry.lock

# Local testing artifacts
test-output/
*.json.backup

# Large/local data artifacts
/data/fraud.csv
/data/*.zip

# Notebook checkpoints
.ipynb_checkpoints/
